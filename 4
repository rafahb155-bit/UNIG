import java.io.IOException;
import java.util.Scanner;

public class Main {
 
    public static void main(String[] args) throws IOException {
        Scanner sc = new Scanner(System.in);
        
        // 1. Ler o valor total em segundos
        int totalSegundos = sc.nextInt();
        
        // 2. Calcular as horas
        // 1 hora tem 3600 segundos (60 * 60)
        int horas = totalSegundos / 3600;
        int resto = totalSegundos % 3600;
        
        // 3. Calcular os minutos
        // O que sobrou das horas dividimos por 60
        int minutos = resto / 60;
        
        // 4. Calcular os segundos
        // O que sobrou dos minutos são os segundos finais
        int segundos = resto % 60;
        
        // 5. Imprimir no formato horas:minutos:segundos
        System.out.println(horas + ":" + minutos + ":" + segundos);
        
        sc.close();
    }
}
